<!-- student.ejs -->

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= student.name %> - Student Details</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="bg-light">

  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Student List App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
    </div>
  </nav>

  <!-- Student Details -->
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <% if (student) { %>
          <div class="card shadow">
            <div class="card-header bg-primary text-white">
              <h3 class="mb-0">Student Details</h3>
            </div>
            <div class="card-body text-center">
              <img src="/images/<%= student.image %>" alt="<%= student.name %>" class="img-fluid rounded mb-3" style="max-height:200px;">
              <h4><%= student.name %></h4>
              <p><strong>Date of Birth:</strong> <%= new Date(student.dob).toISOString().split('T')[0] %></p>
              <p><strong>Contact:</strong> <%= student.contact %></p>

              <div class="d-grid gap-2 mt-3">
                <a href="/editStudent/<%= student.studentId %>" class="btn btn-warning">Edit</a>
                <a href="/deleteStudent/<%= student.studentId %>" class="btn btn-danger"
                   onclick="return confirm('Are you sure you want to delete this student?')">Delete</a>
                <a href="/" class="btn btn-secondary">Back to List</a>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="alert alert-warning text-center">
            <h5>No student found.</h5>
            <a href="/" class="btn btn-secondary mt-3">Back to Home</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

</body>
</html>

